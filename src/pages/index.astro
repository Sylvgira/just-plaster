---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Section from '@components/Section.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import Testimonials from '@components/Testimonials.astro';
import FAQList from '@components/FAQList.astro';
import CTABand from '@components/CTABand.astro';
import TrustBar from '@components/TrustBar.astro';
import { byOrder } from '../lib/content';

const site = await getEntry('settings', 'site');
const home = await getEntry('pages', 'home');
const services = byOrder(await getCollection('services'));
const testimonials = byOrder(await getCollection('testimonials'));
const faqs = byOrder(await getCollection('faqs'));

const hero = home?.data.hero;
---

<BaseLayout>
  <Hero
    variant={hero?.variant ?? 'image-full'}
    mediaPosition={hero?.mediaPosition}
    eyebrow={hero?.eyebrow ?? "Melbourne's Plastering Specialists"}
    title={hero?.title ?? 'Reliable Plastering\nThat Lasts'}
    intro={hero?.intro ?? 'Family owned and operated with over 60 years combined experience. From small patches to full renovations — quality workmanship, fair pricing, and we don\'t leave until you\'re satisfied.'}
    primaryLabel={hero?.primaryLabel ?? 'Fast Free Quote'}
    primaryUrl={hero?.primaryUrl ?? '/contact/'}
    secondaryLabel={hero?.secondaryLabel ?? 'Our Services'}
    secondaryUrl={hero?.secondaryUrl ?? '/services/'}
    imageUrl={hero?.imageUrl ?? '/uploads/hero-plastering.jpg'}
  />

  <TrustBar
    title="Why choose us"
    items={[
      { label: '60+ Years Experience' },
      { label: 'Licensed & Insured' },
      { label: 'Premium Materials' },
      { label: '5-Star Rated' }
    ]}
    ctaLabel="Get a Quote"
    ctaUrl="/contact/"
  />

  <Section
    eyebrow="Our Services"
    title="Complete Plastering Solutions"
    intro="From small repairs to large commercial projects — we have the skills, experience and dedication to deliver exceptional results every time."
  >
    <ServiceGrid services={services} variant={home?.data.servicesVariant ?? 'icon-grid'} />
  </Section>

  <Section
    variant="surface"
    eyebrow="What Our Customers Say"
    title="Trusted by Melbourne Homeowners"
    intro="Don't take our word for it — hear from people we've worked with across Melbourne."
  >
    <Testimonials testimonials={testimonials} variant={home?.data.testimonialsVariant ?? 'grid'} />
  </Section>

  <Section eyebrow="FAQ" title="Common questions">
    <FAQList faqs={faqs} />
  </Section>

  <CTABand
    title="Ready to get started?"
    text="Fill out our quick enquiry form or give us a call — we'll provide a free, no-obligation quote for your plastering project."
    label="Fast Free Quote"
    href="/contact/"
    variant={home?.data.ctaVariant ?? 'band'}
  />
</BaseLayout>
