---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  site: {
    name: string;
    phone?: string;
    ctaLabel?: string;
    ctaUrl?: string;
  };
  pathname: string;
}

const { site, pathname } = Astro.props;
const nav: NavItem[] = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Services', href: '/services/' },
  { label: 'Contact', href: '/contact/' }
];

const isCurrent = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="site-header__brand" href="/" aria-label={`${site.name} home`}>
      <img src="/uploads/justplaster-logo.png" alt="Just Plaster" width="180" height="32" style="height: auto;" />
    </a>
    <nav class="site-header__nav" aria-label="Primary navigation">
      {nav.map((item) => (
        <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
    <a class="site-header__phone" href={`tel:${site.phone}`}>
      {site.phone}
    </a>
    <a class="site-header__cta button site-header__cta--orange" href={site.ctaUrl ?? '/contact/'}>
      {site.ctaLabel ?? 'Fast Free Quote'}
    </a>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-page);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: var(--space-5);
    align-items: center;
    min-height: 5rem;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .site-header__brand img {
    display: block;
  }

  .site-header__nav {
    display: flex;
    gap: var(--space-5);
    align-items: center;
    justify-content: center;
  }

  .site-header__nav a {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 650;
    text-decoration: none;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current='page'] {
    color: var(--color-text);
  }

  .site-header__phone {
    color: var(--brand-primary);
    font-weight: 700;
    font-size: var(--text-sm);
    text-decoration: none;
    white-space: nowrap;
  }

  .site-header__phone:hover {
    text-decoration: underline;
  }

  .site-header__cta {
    min-height: 2.5rem;
    padding-inline: var(--space-4);
  }

  .site-header__cta--orange {
    background: var(--brand-primary);
    color: var(--brand-primary-contrast);
  }

  .site-header__cta--orange:hover {
    background: color-mix(in srgb, var(--brand-primary), black 15%);
  }

  @media (max-width: 920px) {
    .site-header__phone {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .site-header__inner {
      grid-template-columns: 1fr auto;
      gap: var(--space-3);
      padding-block: var(--space-3);
    }

    .site-header__nav {
      grid-column: 1 / -1;
      order: 3;
      justify-content: space-between;
      overflow-x: auto;
      padding-top: var(--space-2);
    }

    .site-header__cta {
      justify-self: end;
    }
  }
</style>
