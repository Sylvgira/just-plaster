---
interface Props {
  site: {
    name: string;
    email?: string;
    phone?: string;
    address?: string;
    socialLinks?: Array<{ label: string; url: string }>;
  };
  variant?: 'default' | 'dark';
}

const { site, variant = 'dark' } = Astro.props;
const year = new Date().getFullYear();
const isDark = variant === 'dark';
---

<footer class:list={['site-footer', isDark && 'site-footer--dark']}>
  <div class="site-footer__inner container">
    <div>
      <a class="site-footer__brand" href="/">{site.name}</a>
      <p>Melbourne's reliable plastering specialists — family owned and operated with over 60 years combined experience. Small to medium job experts.</p>
    </div>
    <div class="site-footer__columns">
      <div>
        <h2>Services</h2>
        <a href="/services/residential-commercial/">Residential & Commercial</a>
        <a href="/services/garage-ceiling-repairs/">Garage Ceiling Repairs</a>
        <a href="/services/renovations/">Renovations</a>
        <a href="/services/patch-repairs/">Patch & Repairs</a>
        <a href="/services/">All Services</a>
      </div>
      <div>
        <h2>Contact</h2>
        {site.phone && <a href={`tel:${site.phone}`} style="font-size: 1.1rem; font-weight: 700;">{site.phone}</a>}
        {site.address && <p>{site.address}</p>}
        <a href="/contact/">Enquire Online</a>
      </div>
      <div>
        <h2>Company</h2>
        <a href="/about/">About Us</a>
        <a href="/contact/">Get a Quote</a>
        {site.socialLinks && site.socialLinks.map((link) => <a href={link.url}>{link.label}</a>)}
      </div>
    </div>
  </div>
  <div class="site-footer__meta container">
    <span>&copy; {year} {site.name} — BUTCON PTY LTD</span>
    <a href="/privacy/">Privacy</a>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    background: var(--color-section);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    gap: var(--space-8);
    padding-block: var(--section-y-compact);
  }

  .site-footer__brand {
    display: inline-block;
    margin-bottom: var(--space-3);
    color: var(--color-heading);
    font-size: var(--text-lg);
    font-weight: 800;
    text-decoration: none;
  }

  .site-footer__columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .site-footer h2 {
    margin-bottom: var(--space-3);
    font-size: var(--text-sm);
  }

  .site-footer a {
    display: block;
    width: fit-content;
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    text-decoration: none;
  }

  .site-footer a:hover {
    color: var(--color-text);
  }

  .site-footer p {
    max-width: 28rem;
    margin-bottom: 0;
    font-size: var(--text-sm);
  }

  .site-footer__meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-rule);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .site-footer__meta a {
    margin: 0;
  }

  /* --- dark variant --- */

  .site-footer--dark {
    border-top: none;
    background: #1a1a1a;
    color: #ffffff;
  }

  .site-footer--dark .site-footer__brand {
    color: #ffffff;
  }

  .site-footer--dark h2 {
    color: rgba(255, 255, 255, 0.55);
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer--dark a {
    color: rgba(255, 255, 255, 0.75);
  }

  .site-footer--dark a:hover {
    color: #ffffff;
  }

  .site-footer--dark p {
    color: rgba(255, 255, 255, 0.65);
  }

  .site-footer--dark .site-footer__meta {
    border-top-color: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.45);
  }

  .site-footer--dark .site-footer__meta a {
    color: rgba(255, 255, 255, 0.45);
  }

  .site-footer--dark .site-footer__meta a:hover {
    color: #ffffff;
  }

  @media (max-width: 760px) {
    .site-footer__inner,
    .site-footer__columns {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .site-footer__meta {
      flex-direction: column;
    }
  }
</style>
