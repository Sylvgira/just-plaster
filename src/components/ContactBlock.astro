---
interface Props {
  email?: string;
  phone?: string;
  address?: string;
}

const { email, phone, address } = Astro.props;
---

<div class="contact-block">
  <div>
    <h2>Contact details</h2>
    <dl>
      {email && (
        <>
          <dt>Email</dt>
          <dd><a href={`mailto:${email}`}>{email}</a></dd>
        </>
      )}
      {phone && (
        <>
          <dt>Phone</dt>
          <dd><a href={`tel:${phone}`}>{phone}</a></dd>
        </>
      )}
      {address && (
        <>
          <dt>Address</dt>
          <dd>{address}</dd>
        </>
      )}
    </dl>
  </div>
  <form name="contact" method="post" data-netlify="false">
    <label>
      Name
      <input type="text" name="name" autocomplete="name" />
    </label>
    <label>
      Email
      <input type="email" name="email" autocomplete="email" />
    </label>
    <label>
      Phone
      <input type="tel" name="phone" autocomplete="tel" />
    </label>
    <label>
      What do you need?
      <textarea name="message" rows="5" placeholder="Tell us about your project..."></textarea>
    </label>
    <button class="button" type="submit">Send enquiry</button>
  </form>
</div>

<style>
  .contact-block {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: var(--space-8);
  }

  dl {
    display: grid;
    gap: var(--space-2);
  }

  dt {
    color: var(--color-text);
    font-weight: 800;
  }

  dd {
    margin: 0 0 var(--space-4);
    color: var(--color-text-muted);
  }

  form {
    display: grid;
    gap: var(--space-4);
  }

  label {
    display: grid;
    gap: var(--space-2);
    color: var(--color-text);
    font-weight: 700;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    padding: 0.85rem 0.95rem;
    background: var(--color-page);
    color: var(--color-text);
  }

  textarea {
    resize: vertical;
  }

  form p {
    margin: 0;
    font-size: var(--text-sm);
  }

  @media (max-width: 820px) {
    .contact-block {
      grid-template-columns: 1fr;
    }
  }
</style>
